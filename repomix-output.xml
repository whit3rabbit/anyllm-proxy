        }
        var spendBtn = el('button', {className: 'btn btn-secondary btn-sm', textContent: 'Spend', style:{marginLeft:'4px'}}, null);
        spendBtn.addEventListener('click', (function(id, prefix) {
          return function() { showKeySpend(id, prefix); };
